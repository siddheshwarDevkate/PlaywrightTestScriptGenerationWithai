{
  "name": "playwrights-ai-templet",
  "version": "1.0.0",
  "description": "Generic AI-powered Playwright test script generator using Claude Agent + Playwright MCP",
  "main": "index.js",
  "scripts": {
    "generate": "ts-node src/runner/generate.ts",
    "test": "playwright test",
    "test:generated": "playwright test --config=generated/playwright.config.ts",
    "install:playwright": "playwright install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/genai": "^2.9.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.14",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
